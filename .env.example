# --- Snowflake Connection (Account & Auth) ---
SNOWFLAKE_ACCOUNT=<your_snowflake_account_identifier>
SNOWFLAKE_USER=<your_username>
SNOWFLAKE_PASSWORD=<your_password>
SNOWFLAKE_WAREHOUSE=<your_warehouse_name>
SNOWFLAKE_ROLE=<your_role_name>

# --- Data Source Identifiers ---
SNOWFLAKE_DATABASE=<your_main_database_name>
SNOWFLAKE_SCHEMA=<your_main_schema_name>
SNOWFLAKE_TABLE_ONE=<primary_property_table_name>
SNOWFLAKE_TABLE_RAW_PROPERTIES=<raw_properties_table_name>

# --- Logging Configuration (Snowflake) ---
SNOWFLAKE_DATABASE_LOGS=<logging_database_name>
SNOWFLAKE_SCHEMA_LOGS=<logging_schema_name>
SNOWFLAKE_TABLE_LOGS=<logging_table_name>
SNOWFLAKE_TABLE_FEEDBACK=<logging_table_feedback_name>

# --- External API Keys ---
GOOGLE_MAPS_KEY=<your_google_maps_api_key>
GEMINI_REAL_ESTATE_USERS_MODEL=<your_gemini_api_key>
RENTCAST_API=<your_rentcast_api_key>

# --- Backend Application Configuration ---
APP_ENV=development  # options: development, production
PORT=8000
